<%= page_heading 'New team' %>
<p class="usa-intro">Create a new team and start creating configurations.</p>
<div class="border-top border-primary-light margin-top-2"></div>
<%= simple_form_for(@team,
    html: { autocomplete: 'off', class: 'usa-form usa-form--large' },
    url: teams_path) do |form| %>
  <%= form.error_notification %>
  <%= render 'form', form: form, agency_required: true, extra_message: nil %>
  <%= form.button :submit, 'Create team', :class => "usa-button" %>
  <br>
  <%= link_to t('forms.buttons.cancel'), teams_path, 
      class: 'usa-button usa-button--unstyled' %>
<% end %>
