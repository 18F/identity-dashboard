
<h1 class="usa-display">Users</h1>

<div class="display-flex">
  <%= button_to t('headings.users.new_user'),
    new_user_path,
    method: :get,
    class: 'usa-button'
  %>

  <% if can_delete_unconfirmed_users?(current_user) %>
    <%= button_to t('forms.buttons.delete_unconfirmed_users'),
      delete_unconfirmed_users_path,
      method: :delete,
      class: 'usa-button' %>
  <% end %>
</div>

<% if @total_pages > 1 %>
  <nav aria-label="Pagination" class="margin-y-2">
    <% if @page > 1 %>
      <%= link_to 'First', users_path(page: 1), class: 'usa-button usa-button--outline' %>
      <%= link_to 'Previous', users_path(page: @page - 1), class: 'usa-button usa-button--outline' %>
    <% end %>
    <% ([@page - 2, 1].max..[@page + 2, @total_pages].min).each do |pg| %>
      <% if pg == @page %>
        <span class="usa-button"><%= pg %></span>
      <% else %>
        <%= link_to pg, users_path(page: pg), class: 'usa-button usa-button--outline' %>
      <% end %>
    <% end %>
    <% if @page < @total_pages %>
      <%= link_to 'Next', users_path(page: @page + 1), class: 'usa-button usa-button--outline' %>
      <%= link_to 'Last', users_path(page: @total_pages), class: 'usa-button usa-button--outline' %>
    <% end %>
  </nav>
<% end %>

<table class="usa-table">
  <thead>
    <tr>
      <th scope="col">Email</th>
      <th scope="col">Signed in?</th>
      <th scope="col"><%=
        IdentityConfig.store.access_controls_enabled ? 'Role' : 'Admin'
      %></th>
      <th scope="col">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= image_tag sign_in_icon(user), height: '27', width: '27',
                          title: title(user),
                          alt: alt(user),
                          aria: { hidden: true },
                          style: 'vertical-align:bottom' %>
          <%= caption(user) %>
        </td>
        <td>
          <% if IdentityConfig.store.access_controls_enabled %>
            <%= user.primary_role.friendly_name %>
          <% else %>
            <%= image_tag 'security-key.svg',
                            height: '27', width: '27',
                            alt: 'admin user',
                            aria: { hidden: true } if user.logingov_admin? %>
          <% end %>
        </td>
        <td>
          <%= button_to 'Delete', user_path(user.id), method: :delete,
                      form_class: 'display-inline',
                      class: 'usa-button usa-button--unstyled usa-link margin-right-1',
                      data: { confirm: t('notices.confirm_delete') } %>
          <span>&nbsp;</span>
          <%= link_to 'Edit', edit_user_path(user.id), class: 'usa-link' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @total_pages > 1 %>
  <nav aria-label="Pagination" class="margin-y-2">
    <% if @page > 1 %>
      <%= link_to 'First', users_path(page: 1), class: 'usa-button usa-button--outline' %>
      <%= link_to 'Previous', users_path(page: @page - 1), class: 'usa-button usa-button--outline' %>
    <% end %>
    <% ([@page - 3, 1].max..[@page + 3, @total_pages].min).each do |pg| %>
      <% if pg == @page %>
        <span class="usa-button"><%= pg %></span>
      <% else %>
        <%= link_to pg, users_path(page: pg), class: 'usa-button usa-button--outline' %>
      <% end %>
    <% end %>
    <% if @page < @total_pages %>
      <%= link_to 'Next', users_path(page: @page + 1), class: 'usa-button usa-button--outline' %>
      <%= link_to 'Last', users_path(page: @total_pages), class: 'usa-button usa-button--outline' %>
    <% end %>
  </nav>
<% end %>
