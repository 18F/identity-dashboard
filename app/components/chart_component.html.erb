<div class="data-graph--container">
  <p class="data-graph__title">
    <span class="data-graph__headline"><%= title %></span>
  </p>
  <p class="padding-bottom-2"><%= top_description %></p>
      <% if data_unavailable? %>
        <div class="grid-row flex-row bg-primary-lightest chart-sized maxw-full">
          <div class="flex-fill flex-align-self-center text-center">
            <%= t('reports.errors.unavailable_data') %>
          </div>
        </div>
      <% else %>
        <%# Chartkick needs to keep track of a unique ID sequence, so it needs to be called from
          # a shared context (`helpers`) instead of included in the component class directly %>
        <%= helpers.public_send(type, data, **options) %>
      <% end %>
  <p><%= bottom_description %></p>
</div>
